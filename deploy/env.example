# Copy to /etc/standardization-webapp/env on the server, set values, and
# `chown root:www-data /etc/standardization-webapp/env` and `chmod 640
# /etc/standardization-webapp/env` so root and the www-data service user can
# read it.

# --- Database ---
# The DBA must provision a Postgres role and a schema. The role needs
# USAGE+CREATE on the schema and CONNECT on the database. The schema is
# already provisioned in our setup (currently `standardization_app`) — the
# app only manages tables INSIDE that schema.
DB_HOST=taimaka-internal.org
DB_PORT=5432
DB_NAME=cmam
DB_USER=standardization_developer
DB_PASSWORD='change-me'
DATABASE_URL='postgresql://USER:PASSWORD@HOST:5432/cmam'
DATABASE_SCHEMA=standardization_app

# --- Email (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM='Standardization Webapp <noreply@taimaka-internal.org>'

# --- Auth.js ---
# In production, NEXTAUTH_URL must match the public hostname.
NEXTAUTH_URL=https://standardization.taimaka-internal.org
# Generate once with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me

# --- Token-at-rest encryption ---
# 64 hex chars = 32 bytes. Generate with: openssl rand -hex 32
TOKEN_ENCRYPTION_KEY=change-me

# --- ODK Central ---
ODK_DEFAULT_BASE_URL=https://taimaka-internal.org:7443

# --- Signup gate ---
SIGNUP_ALLOWED_DOMAIN=taimaka.org

# --- Node ---
NODE_ENV=production
# Runtime port is set in deploy/standardization-webapp.service. The deploy
# template uses 3001 so this app can run beside another Next.js app on 3000.
